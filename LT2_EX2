.data
	msg1: .asciiz "\nDigite o raio da circunferência: "
	msg2: .asciiz "\nComprimento da circunferência: "
.text
main:
	#Raio da circunferência
	li $v0, 4
	la $a0, msg1
	syscall
	
	li $v0, 5
	syscall
	add $t0, $a0, 0
	
	#Cálculo da circunferência
	mul $t1,$t0,3
	
	#Mostrar mensagem
	li $v0, 4
	la $a0, msg2
	syscall
	
	#Mostrar resultado
	li $v0, 1
	add $a0, $t1, 0
	syscall
	
	#Encerrar
	li $v0, 10
	syscall
